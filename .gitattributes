# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF
*.py    text eol=lf
*.md    text eol=lf
*.rst   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.ipynb text eol=lf
Makefile text eol=lf

# Binary — no line ending conversion
*.png   binary
*.jpg   binary
*.pdf   binary
*.zip   binary
